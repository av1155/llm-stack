#!/usr/bin/env bash
# Download the canonical Unsloth Qwen3.6 GGUFs into $MODELS_HOME (default
# ~/models/), laid out as one HF-repo-named directory per model:
#
#   ~/models/Qwen3.6-27B-GGUF/Qwen3.6-27B-UD-Q6_K_XL.gguf
#   ~/models/Qwen3.6-35B-A3B-GGUF/Qwen3.6-35B-A3B-UD-Q4_K_XL.gguf
#   ~/models/Qwen3.6-35B-A3B-GGUF/mmproj-F32.gguf
#
# huggingface-cli is idempotent — it skips files already present whose
# checksums match. Re-running this is cheap.
#
# Usage:
#   bin/models all                          # both profiles
#   bin/models qwen3.6-27b-agent            # just the 27B dense GGUF
#   bin/models qwen3.6-35b-a3b-thinking     # the 35B-A3B GGUF + mmproj

set -euo pipefail

MODELS_HOME="${MODELS_HOME:-$HOME/models}"

usage() {
    cat <<'EOF'
Usage: models {all|qwen3.6-27b-agent|qwen3.6-35b-a3b-thinking}

Downloads canonical Unsloth GGUFs to $MODELS_HOME/<repo-basename>/.
Default MODELS_HOME is $HOME/models.
EOF
}

download_27b_agent() {
    local target="${MODELS_HOME}/Qwen3.6-27B-GGUF"
    mkdir -p "${target}"
    echo "[models] Qwen3.6-27B-UD-Q6_K_XL → ${target}"
    huggingface-cli download unsloth/Qwen3.6-27B-GGUF \
        Qwen3.6-27B-UD-Q6_K_XL.gguf \
        --local-dir "${target}"
}

download_35b_a3b_thinking() {
    local target="${MODELS_HOME}/Qwen3.6-35B-A3B-GGUF"
    mkdir -p "${target}"
    echo "[models] Qwen3.6-35B-A3B-UD-Q4_K_XL + mmproj-F32 → ${target}"
    huggingface-cli download unsloth/Qwen3.6-35B-A3B-GGUF \
        Qwen3.6-35B-A3B-UD-Q4_K_XL.gguf \
        mmproj-F32.gguf \
        --local-dir "${target}"
}

case "${1:-}" in
    all)
        download_27b_agent
        download_35b_a3b_thinking
        ;;
    qwen3.6-27b-agent)
        download_27b_agent
        ;;
    qwen3.6-35b-a3b-thinking)
        download_35b_a3b_thinking
        ;;
    ""|-h|--help)
        usage
        exit 0
        ;;
    *)
        echo "models: unknown profile: $1" >&2
        usage >&2
        exit 1
        ;;
esac
