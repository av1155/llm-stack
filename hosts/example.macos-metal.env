# Template host config for a new macOS + Apple Silicon (Metal) machine.
# Copy to hosts/$(hostname -s | tr 'A-Z' 'a-z').env and adjust the values.
# After copying, set LLM_STACK_HOST in your shell rc to match the filename
# (install.sh does this automatically when run on this machine).

HOST_BIND=127.0.0.1

# Match the number of performance cores. M4 Max has 10P; M3 Pro has 6P.
# Use `sysctl -n hw.perflevel0.physicalcpu` to check.
THREADS=10

AGENT_MODEL_DIR="$HOME/models/Qwen3.6-27B-GGUF"
AGENT_MODEL_FILE="Qwen3.6-27B-UD-Q6_K_XL.gguf"

# Unified memory makes the ctx ceiling much more generous than discrete VRAM.
# 131K covers most agentic workloads; bump to 262144 if running solo.
AGENT_CTX_SIZE=131072

# Thinking profile (agentic coding / vision). Comment out if you only
# run the agent profile.
THINKING_MODEL_DIR="$HOME/models/Qwen3.6-35B-A3B-GGUF"
THINKING_MODEL_FILE="Qwen3.6-35B-A3B-UD-Q4_K_XL.gguf"
THINKING_MMPROJ_FILE="mmproj-F32.gguf"
THINKING_CTX_SIZE=262144
