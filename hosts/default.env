# llm-stack: shared defaults across all hosts.
#
# Per-host files in this directory override these values. Profile scripts
# source default.env first, then the host-specific file, so anything set
# below is a fallback the host can override.

# Bind to loopback only by default. Override to 0.0.0.0 on hosts where the
# server has to be reachable across an OS / VM boundary (e.g. WSL2).
HOST_BIND=127.0.0.1

# Prompt cache size in MiB. 16 GiB doubles the upstream default (8 GiB) so
# long agentic runs stop evicting useful checkpoints. Costs system RAM
# only (not VRAM). Drop to 8192 on memory-constrained hosts.
CACHE_RAM=16384
