# MacBook Pro 16": Apple M4 Max, 64 GB unified memory
# llama.cpp: brew install llama.cpp (Metal backend, auto-updated)

HOST_BIND=127.0.0.1
THREADS=10

AGENT_MODEL_DIR="$HOME/models/Qwen3.6-27B-GGUF"
AGENT_MODEL_FILE="Qwen3.6-27B-UD-Q6_K_XL.gguf"
# 131K covers TradingAgents Deep runs (5 debate rounds + 5 risk rounds
# accumulate ~50-60K tokens by the Portfolio Manager step). KV cache
# cost is ~8 GiB; fits in unified memory comfortably.
AGENT_CTX_SIZE=131072

THINKING_MODEL_DIR="$HOME/models/Qwen3.6-35B-A3B-GGUF"
THINKING_MODEL_FILE="Qwen3.6-35B-A3B-UD-Q4_K_XL.gguf"
# Vision tower for the thinking profile. Unsloth ships BF16/F16/F32
# variants in the same HF repo; F32 is highest precision and smallest
# overhead since image tokens are <1% of context.
THINKING_MMPROJ_FILE="mmproj-F32.gguf"
# 262K is the model's full trained context; M4 Max has the unified
# memory to back it. Drop to 131072 if running both servers concurrently.
THINKING_CTX_SIZE=262144
