# Andrea-PC: WSL2 Ubuntu 24.04 + RTX 5090 (Blackwell, SM 120, 32 GB VRAM)
# CPU: AMD Ryzen 7 9800X3D (8C/16T)
# llama.cpp: built from source at ~/llama.cpp (CUDA toolkit 12.9)

HOST_BIND=0.0.0.0
THREADS=16

# Blackwell-specific flags. --kv-unified enables --cache-idle-slots
# (saves and clears idle slots on new task). --fit-target 256 lowers the
# default 1024 MiB free-VRAM target so the boot-time fit logic stops
# warning about "cannot meet free memory target". This host runs with
# ~840 MiB headroom by design.
EXTRA_AGENT_FLAGS="--kv-unified --fit-target 256"

AGENT_MODEL_DIR="$HOME/models/Qwen3.6-27B-GGUF"
AGENT_MODEL_FILE="Qwen3.6-27B-UD-Q6_K_XL.gguf"
# 98K is below the model's trained 262K context but matches the VRAM
# budget: KV cache at ctx=98K with FP16 is ~6 GiB, leaving room for
# weights (23 GiB) + compute buffer + headroom. Raising it risks OOM.
AGENT_CTX_SIZE=98304

# Thinking profile intentionally not configured on this host.
# Use case is TradingAgents only; agentic coding lives on the Mac.
# Setting THINKING_* here would only matter if you start using
# OpenCode / similar on Windows. See docs/profiles.md.

# MTP variant of the agent profile. Multi-Token Prediction speculative
# decoding, roughly 1.4x faster generation than the non-MTP server, with
# output distribution identical by construction (rejection sampling).
# Same Qwen3.6-27B dense weights from Unsloth's MTP repo, same sampler.
MTP_AGENT_MODEL_DIR="$HOME/models/Qwen3.6-27B-MTP-GGUF"
MTP_AGENT_MODEL_FILE="Qwen3.6-27B-UD-Q6_K_XL.gguf"
MTP_AGENT_CTX_SIZE=98304

# MTP draft heads add ~1 GB VRAM beyond the base model. Quantizing the
# KV cache to q8_0 (both K and V) halves its footprint with near-zero
# quality cost, freeing ~3 GB. This is what makes MTP fit on the 5090
# at ctx=98304 without dropping context. See docs/vram-tuning.md.
MTP_EXTRA_AGENT_FLAGS="--kv-unified --fit-target 256 --cache-type-k q8_0 --cache-type-v q8_0"
