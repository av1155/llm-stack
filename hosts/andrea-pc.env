# Andrea-PC — WSL2 Ubuntu 24.04 + RTX 5090 (Blackwell, SM 120, 32 GB VRAM)
# CPU: AMD Ryzen 7 9800X3D (8C/16T)
# llama.cpp: built from source at ~/llama.cpp (CUDA toolkit 13.2)

HOST_BIND=0.0.0.0
THREADS=16

# Blackwell-specific flags. --kv-unified enables --cache-idle-slots
# (saves and clears idle slots on new task). --fit-target 256 lowers the
# default 1024 MiB free-VRAM target so the boot-time fit logic stops
# warning about "cannot meet free memory target" — we run with ~840 MiB
# headroom by design.
EXTRA_AGENT_FLAGS="--kv-unified --fit-target 256"

AGENT_MODEL_DIR="$HOME/models/Qwen3.6-27B-GGUF"
AGENT_MODEL_FILE="Qwen3.6-27B-UD-Q6_K_XL.gguf"
# 98K is below the model's trained 262K context but matches the VRAM
# budget: KV cache at ctx=98K with FP16 is ~6 GiB, leaving room for
# weights (23 GiB) + compute buffer + headroom. Raising it risks OOM.
AGENT_CTX_SIZE=98304

# Thinking profile intentionally not configured on this host.
# Use case is TradingAgents only; agentic coding lives on the Mac.
# Setting THINKING_* here would only matter if you start using
# OpenCode / similar on Windows. See docs/profiles.md.
