# Template host config for a new Linux + NVIDIA CUDA box.
# Copy to hosts/$(hostname -s | tr 'A-Z' 'a-z').env and adjust the values.
# After copying, set LLM_STACK_HOST in your shell rc to match the filename
# (install.sh does this automatically when run on this machine).

# 0.0.0.0 if the server has to be reachable across a VM / WSL boundary.
HOST_BIND=127.0.0.1

# Match nproc on the host.
THREADS=16

# Optional Blackwell / Ada-Lovelace tuning. Drop --kv-unified if you don't
# care about cache-idle-slots; drop --fit-target if your VRAM has plenty
# of headroom at your chosen ctx-size.
EXTRA_AGENT_FLAGS="--kv-unified --fit-target 256"

# Where the hf CLI put the models (bin/models defaults to ~/models/).
AGENT_MODEL_DIR="$HOME/models/Qwen3.6-27B-GGUF"
AGENT_MODEL_FILE="Qwen3.6-27B-UD-Q6_K_XL.gguf"

# Set ctx-size to whatever your VRAM allows. KV cache at FP16 is roughly
# 6 GiB per 98K tokens with this model. See docs/vram-tuning.md.
AGENT_CTX_SIZE=98304

# Uncomment to enable the thinking profile on this host:
# THINKING_MODEL_DIR="$HOME/models/Qwen3.6-35B-A3B-GGUF"
# THINKING_MODEL_FILE="Qwen3.6-35B-A3B-UD-Q4_K_XL.gguf"
# THINKING_MMPROJ_FILE="mmproj-F32.gguf"
# THINKING_CTX_SIZE=131072

# Uncomment to enable the MTP variant of the agent profile (~1.4x faster
# generation, identical output distribution, ~1 GB extra VRAM). On
# tight-VRAM hosts, pair with KV cache quant in MTP_EXTRA_AGENT_FLAGS to
# free ~3 GB. See docs/profiles.md.
# MTP_AGENT_MODEL_DIR="$HOME/models/Qwen3.6-27B-MTP-GGUF"
# MTP_AGENT_MODEL_FILE="Qwen3.6-27B-UD-Q6_K_XL.gguf"
# MTP_AGENT_CTX_SIZE=98304
# MTP_EXTRA_AGENT_FLAGS="--kv-unified --fit-target 256 --cache-type-k q8_0 --cache-type-v q8_0"
